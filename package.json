{
  "name": "@alexbruf/d1-level",
  "version": "0.2.0",
  "description": "An abstract-level database backed by Cloudflare D1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
